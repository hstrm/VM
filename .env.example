# Kopiera den här filen till .env och fyll i dina värden från Supabase
# Hitta dem under: supabase.com > ditt projekt > Settings > API

VITE_SUPABASE_URL=https://DITT-PROJEKT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=din-anon-nyckel-här

# Välj ett eget lösenord för adminsidan
VITE_ADMIN_PASSWORD=välj-ett-bra-lösenord
